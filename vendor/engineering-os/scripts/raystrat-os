#!/usr/bin/env bash
# raystrat-os — Engineering OS CLI
#
# Thin router over OS backing scripts. Zero business logic.
# Every command delegates directly to a backing script via exec.
# Exit codes propagated unchanged.
#
# Usage: raystrat-os <command> [args]

# ── Script location → OS root ──────────────────────────────────────────────
# realpath resolves through symlinks so ~/bin/raystrat-os → scripts/raystrat-os
# works correctly. OS_ROOT is the repo root (parent of scripts/).

SCRIPT_PATH="$(realpath "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
OS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── Root detection ─────────────────────────────────────────────────────────

if [ ! -d "$OS_ROOT/scripts" ]; then
  echo "ERROR: OS scripts not found — invalid installation or broken symlink" >&2
  exit 1
fi

# ── Adapter config: source if present ─────────────────────────────────────
# Optional. Sourced before any command so EOS_* vars are available.
# No validation — backing scripts handle missing vars themselves.

if [ -f ".engineering-os/adapter.config.sh" ]; then
  # shellcheck disable=SC1091
  . ".engineering-os/adapter.config.sh"
fi

# ── Usage ─────────────────────────────────────────────────────────────────

usage() {
  cat >&2 <<'USAGE'
Usage: raystrat-os <command> [args]

Commands:
  boot                                  Validate OS environment
  check [--config <path>]               Validate adapter configuration contract
  verify [--only <INV-ID>]              Run invariant checks
  status <feature>                      Print feature pipeline state
  state <get|advance|require|reset> ... Full state machine access
  compile <spec-file>                   Compile approved spec -> task graph
  exec <feature>                        Execute feature task graph
  intent <one-line intent>              Create spec + run full pipeline from intent
  regress                               Run full verification regression
  self-test                             Run OS self-test suite
USAGE
  exit 1
}

# ── Command dispatch ───────────────────────────────────────────────────────

CMD="${1:-}"
[ $# -gt 0 ] && shift

case "$CMD" in

  boot)
    exec bash "$OS_ROOT/scripts/os-boot-check.sh" "$@"
    ;;

  check)
    exec bash "$OS_ROOT/scripts/os-adapter-check.sh" "$@"
    ;;

  verify)
    exec bash "$OS_ROOT/scripts/invariant-engine.sh" "$@"
    ;;

  status)
    if [ -z "${1:-}" ]; then
      echo "ERROR: status requires a feature slug" >&2
      echo "Usage: raystrat-os status <feature>" >&2
      exit 1
    fi
    exec bash "$OS_ROOT/scripts/state-manager.sh" get "$@"
    ;;

  state)
    exec bash "$OS_ROOT/scripts/state-manager.sh" "$@"
    ;;

  compile)
    if [ -z "${1:-}" ]; then
      echo "ERROR: compile requires a spec file path" >&2
      echo "Usage: raystrat-os compile <spec-file>" >&2
      exit 1
    fi
    exec bash "$OS_ROOT/scripts/compile-spec.sh" "$@"
    ;;

  exec)
    if [ -z "${1:-}" ]; then
      echo "ERROR: exec requires a feature slug" >&2
      echo "Usage: raystrat-os exec <feature>" >&2
      exit 1
    fi
    exec bash "$OS_ROOT/scripts/execution-supervisor.sh" "$@"
    ;;

  intent)
    if [ -z "${1:-}" ]; then
      echo "ERROR: intent requires a one-line intent string" >&2
      echo "Usage: raystrat-os intent \"<one-line intent>\"" >&2
      exit 1
    fi
    exec bash "$OS_ROOT/scripts/os-intent-entry.sh" "$@"
    ;;

  regress)
    exec bash "$OS_ROOT/scripts/run-full-regression.sh" "$@"
    ;;

  self-test)
    exec bash "$OS_ROOT/scripts/os-self-test.sh" "$@"
    ;;

  "" | -h | --help)
    usage
    ;;

  *)
    echo "ERROR: unknown command: $CMD" >&2
    echo "" >&2
    usage
    ;;

esac
